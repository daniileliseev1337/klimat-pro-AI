# apartment-tracker — секреты
# Скопируй в ./.env в корне проекта и заполни свои значения.

# Получить бот-токен: создать бота через @BotFather в Telegram
TELEGRAM_BOT_TOKEN=

# Узнать свой chat_id: написать боту любое сообщение, потом открыть
# https://api.telegram.org/bot<TOKEN>/getUpdates — chat.id будет в JSON
TELEGRAM_CHAT_ID=
